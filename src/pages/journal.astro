---
import { getCollection } from "astro:content";
import ContentLayout from "../layouts/ContentLayout.astro";

const posts = await getCollection("journal");
---

<ContentLayout title="Notes from rehearsal, edition, and archive." eyebrow="Journal" description="Essays, production notes, and records from the workbench behind the music.">
  <div class="grid gap-8">
    {posts.map((post) => (
      <a class="grid gap-5 border-t border-sand-1/14 py-8 transition hover:border-accent md:grid-cols-[1fr_2fr]" href={`/journal/${post.slug}`}>
        <p class="font-mono text-[0.68rem] uppercase tracking-[0.14em] text-accent">{post.data.date}</p>
        <div>
          <h2 class="font-display text-3xl text-sand-1">{post.data.title}</h2>
          <p class="mt-3 font-serif text-lg italic leading-8 text-sand-1/68">{post.data.dek}</p>
        </div>
      </a>
    ))}
  </div>
</ContentLayout>
