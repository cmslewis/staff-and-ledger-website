---
import ContentLayout from "../layouts/ContentLayout.astro";
import { getCollection } from "astro:content";

const editions = await getCollection("publishing");
---

<ContentLayout title="Editions made for rehearsal and record." eyebrow="Publishing" description="The publishing desk creates clear, beautiful vocal scores that honor the composer's intent and the singer's hand.">
  <div class="grid gap-6">
    {editions.map((edition) => (
      <a class="grid gap-3 border-t border-sand-1/14 py-6 transition hover:border-accent md:grid-cols-[10rem_1fr]" href={`/publishing/${edition.slug}`}>
        <p class="font-mono text-[0.68rem] uppercase tracking-[0.14em] text-accent">Edition</p>
        <div>
          <h2 class="font-display text-3xl text-sand-1">{edition.data.title}</h2>
          <p class="mt-2 font-sans text-sm leading-7 text-sand-1/62">{edition.data.description}</p>
        </div>
      </a>
    ))}
  </div>
</ContentLayout>
