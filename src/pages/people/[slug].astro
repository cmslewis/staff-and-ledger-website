---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

export async function getStaticPaths() {
  const profiles = await getCollection("people");
  return profiles.map((profile) => ({ params: { slug: profile.slug }, props: { profile } }));
}

const { profile } = Astro.props;
const { Content } = await render(profile);
---

<BaseLayout title={profile.data.title} description={profile.data.description} image={profile.data.image}>
  <article class="section-y min-h-screen pt-36">
    <div class="site-shell site-grid gap-y-12">
      <aside class="col-span-4 md:col-span-3">
        <p class="folio-label">People</p>
      </aside>
      <div class="col-span-4 md:col-span-7 lg:col-span-8 lg:col-start-5">
        <h1 class="font-display text-section-sm leading-tight text-sand-1 md:text-section-lg">{profile.data.title}</h1>
        <p class="mt-6 max-w-3xl font-serif text-2xl italic leading-10 text-accent">{profile.data.description}</p>
        <div class="prose prose-invert mt-16 max-w-3xl font-serif text-lg leading-9 text-sand-1/76">
          <Content />
        </div>
      </div>
    </div>
  </article>
</BaseLayout>
