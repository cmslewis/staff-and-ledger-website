---
import { getCollection } from "astro:content";
import ContentLayout from "../layouts/ContentLayout.astro";

const profiles = await getCollection("people");
---

<ContentLayout title="Artists, editors, and collaborators." eyebrow="People" description="The working table behind Staff & Ledger: performers, editors, conductors, and partners shaping each season.">
  <div class="grid gap-6">
    {profiles.map((profile) => (
      <a class="grid gap-3 border-t border-sand-1/14 py-6 transition hover:border-accent md:grid-cols-[10rem_1fr]" href={`/people/${profile.slug}`}>
        <p class="font-mono text-[0.68rem] uppercase tracking-[0.14em] text-accent">Profile</p>
        <div>
          <h2 class="font-display text-3xl text-sand-1">{profile.data.title}</h2>
          <p class="mt-2 font-sans text-sm leading-7 text-sand-1/62">{profile.data.description}</p>
        </div>
      </a>
    ))}
  </div>
</ContentLayout>
