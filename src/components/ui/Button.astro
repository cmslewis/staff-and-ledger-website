---
interface Props {
  href: string;
  label: string;
  tone?: "dark" | "paper";
}

const { href, label, tone = "dark" } = Astro.props;
const classes = tone === "paper"
  ? "border-ink/35 text-ink hover:bg-ink hover:text-paper"
  : "border-accent/65 text-accent hover:bg-accent hover:text-ink";
---

<a class={`inline-flex min-h-12 items-center border px-5 font-sans text-xs uppercase tracking-[0.16em] transition ${classes}`} href={href}>
  {label}
</a>
