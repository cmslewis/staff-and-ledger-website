---
import PillarCard from "../cards/PillarCard.astro";
import SectionLabel from "../ui/SectionLabel.astro";

const { block } = Astro.props;
---

<section class="section-y paper-band staff-lines">
  <div class="site-shell site-grid gap-y-12">
    <div class="col-span-4 md:col-span-3">
      <SectionLabel label={block.sectionLabel} mark="SL/02" />
    </div>
    <div class="col-span-4 md:col-span-8 lg:col-span-9 lg:col-start-4">
      <h2 class="max-w-4xl font-display text-section-sm leading-tight md:text-section-lg">Performance, publishing, and archive share one table.</h2>
      <div class="mt-16 grid gap-8 lg:grid-cols-3">
        {block.items.map((item) => <PillarCard {...item} />)}
      </div>
    </div>
  </div>
</section>
