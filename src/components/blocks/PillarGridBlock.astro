---
import PillarCard from "../cards/PillarCard.astro";
const { block } = Astro.props;
---

<section class="bg-page">
  <div class="grid border-y border-sand-1/12 lg:grid-cols-[clamp(4rem,5vw,5.75rem)_1fr]">
    <div class="hidden border-r border-sand-1/12 px-6 py-8 lg:block">
      <p class="font-mono text-sm text-sand-1/72">02</p>
    </div>
    <div>
      <div class="border-b border-sand-1/12 px-6 py-5 lg:hidden">
        <p class="font-mono text-sm text-sand-1/72">02</p>
      </div>
      <div class="grid lg:grid-cols-3">
        {block.items.map((item) => <PillarCard {...item} />)}
      </div>
    </div>
  </div>
</section>
