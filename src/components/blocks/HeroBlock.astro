---
import Button from "../ui/Button.astro";
import ConcertParchmentCard from "../cards/ConcertParchmentCard";

const { block } = Astro.props;
const headlineParts = String(block.headline ?? "")
	.split(/(_[^_]+_)/g)
	.filter(Boolean);

const foundedByParts = String(block.foundedBy ?? "")
	.split(/(\*[^*]+\*)/g)
	.filter(Boolean);
---

<section class="relative min-h-screen overflow-hidden bg-page pt-20">
  <img class="hero-image-reveal absolute inset-0 h-full w-full object-cover" src={block.image} alt={block.imageAlt} loading="eager" />
  <div class="absolute inset-0 bg-[linear-gradient(90deg,var(--color-page)_0%,var(--color-page)_15%,transparent_100%)]"></div>
  <div class="site-shell relative z-10 grid min-h-[calc(100vh-5rem)] items-center gap-12 py-[clamp(48px,7vw,96px)] lg:grid-cols-12 lg:gap-8">
    <div class="lg:col-span-8">

      <!-- Heading -->
      <h1 class="hero-reveal my-8 font-display text-hero-sm leading-[1.1] text-sand-1 md:mb-12 md:text-hero-md lg:text-hero-lg lg:leading-[1.15]">
        {headlineParts.map((part) =>
          part.startsWith("_") && part.endsWith("_") ? (
            <em class="text-accent italic">{part.slice(1, -1)}</em>
          ) : (
            part
          )
        )}

        <span class="hero-title-rule mt-8 block w-1/6 border-b border-b-muted md:mt-12" aria-hidden="true"></span>
      </h1>


      <div class="flex flex-col gap-4 md:gap-6 lg:max-w-[34rem]">
       <div class="folio-label hero-reveal hero-reveal-2">{block.annotation}</div>

        <!-- Blurb -->
        <p class="hero-reveal hero-reveal-2 font-serif text-lede leading-8 text-sand-1/78 md:text-lede-md">{block.body}</p>

        <!-- Founded By -->
        <p class="hero-reveal hero-reveal-2 font-serif text-lede leading-8 text-sand-1/78 md:text-lede-md">
          {foundedByParts.map((part) =>
            part.startsWith("*") && part.endsWith("*") ? (
              <span class="text-accent">{part.slice(1, -1)}</span>
            ) : (
              part
            )
          )}
        </p>

        <!-- Button -->
        {block.ctaUrl && block.ctaUrl && <div class="hero-reveal hero-reveal-2 mt-2">
          <Button href={block.ctaUrl} label={block.ctaLabel} />
        </div>}
      </div>
    </div>

    {block.concertCard && (
      <aside class="hero-reveal hero-card-reveal concert-card-wrap lg:col-span-4 lg:col-start-9" aria-label="Featured concert">
        <ConcertParchmentCard {...block.concertCard} />
      </aside>
    )}
  </div>
</section>

<style>
  .concert-card-wrap {
    justify-self: center;
    width: min(100%, 26rem);
  }

  .hero-reveal {
    animation: hero-reveal 2.5s cubic-bezier(0.22, 1, 0.36, 1) both;
    opacity: 0;
    transform: translateY(15px) scale(0.98);
    animation-delay: 200ms;
  }

  .hero-image-reveal {
    animation: hero-image-reveal 3s cubic-bezier(0.22, 1, 0.36, 1) both;
    animation-delay: 200ms;
    opacity: 0;
  }

  .hero-title-rule {
    animation: hero-rule-draw 1.25s cubic-bezier(0.22, 1, 0.36, 1) both;
    animation-delay: 400ms;
    transform: scaleX(0);
    transform-origin: left center;
  }

  .hero-reveal-2 {
    animation-delay: 600ms;
  }

  .hero-card-reveal {
    animation: hero-card-reveal 2.5s cubic-bezier(0.22, 1, 0.36, 1) both;
    animation-delay: 1100ms;
    transform-origin: 25% 25%;
    transform: translateY(-10px) rotate(-1deg);
  }


  @keyframes hero-reveal {
    to {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }

  @keyframes hero-image-reveal {
    to {
      opacity: 1;
    }
  }

  @keyframes hero-rule-draw {
    to {
      transform: scaleX(1);
    }
  }

  @keyframes hero-card-reveal {
    to {
      opacity: 1;
      transform: translateY(0) rotate(1deg);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-reveal,
    .hero-image-reveal,
    .hero-title-rule,
    .hero-card-reveal {
      animation: none;
      opacity: 1;
      transform: none;
    }

  }

</style>
