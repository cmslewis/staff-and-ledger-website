---
import Button from "../ui/Button.astro";
import SectionLabel from "../ui/SectionLabel.astro";

const { block } = Astro.props;
const headlineParts = String(block.headline ?? "")
	.split(/(_[^_]+_)/g)
	.filter(Boolean);

const foundedByParts = String(block.foundedBy ?? "")
	.split(/(\*[^*]+\*)/g)
	.filter(Boolean);
---

<section class="relative min-h-screen overflow-hidden bg-page pt-20">
  <img class="hero-image-reveal absolute inset-0 h-full w-full object-cover" src={block.image} alt={block.imageAlt} loading="eager" />
  <div class="absolute inset-0 bg-[linear-gradient(90deg,var(--color-page)_0%,var(--color-page)_15%,transparent_100%)]"></div>
  <div class="site-shell relative z-10 flex min-h-[calc(100vh-5rem)] items-center py-[clamp(48px,7vw,96px)]">
    <div class="w-full">

      <!-- Heading -->
      <h1 class="hero-reveal my-8 md:max-w-2/3 lg:md:max-w-2/3 font-display text-hero-sm leading-[1.1] text-sand-1 md:mb-12 md:text-hero-md lg:text-hero-lg lg:leading-[1.15]">
        {headlineParts.map((part) =>
          part.startsWith("_") && part.endsWith("_") ? (
            <em class="text-accent italic">{part.slice(1, -1)}</em>
          ) : (
            part
          )
        )}

        <div class="w-1/6 border-b border-b-muted mt-8 md:mt-12"></div>
      </h1>


      <div class="flex flex-col gap-4 md:gap-6 md:max-w-2/3 lg:max-w-1/2">
       <div class="folio-label hero-reveal hero-reveal-2">{block.annotation}</div>

        <!-- Blurb -->
        <p class="hero-reveal hero-reveal-3 font-serif text-lede leading-8 text-sand-1/78 md:text-lede-md">{block.body}</p>

        <!-- Founded By -->
        <p class="hero-reveal hero-reveal-4 font-serif text-lede leading-8 text-sand-1/78 md:text-lede-md">
          {foundedByParts.map((part) =>
            part.startsWith("*") && part.endsWith("*") ? (
              <span class="text-accent">{part.slice(1, -1)}</span>
            ) : (
              part
            )
          )}
        </p>

        <!-- Button -->
        <div class="hero-reveal hero-reveal-5 mt-2">
          <Button href={block.ctaUrl} label={block.ctaLabel} />
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero-reveal {
    animation: hero-reveal 2.5s cubic-bezier(0.22, 1, 0.36, 1) both;
    opacity: 0;
    transform: translateY(15px) scale(0.98);
    animation-delay: 200ms;
  }

  .hero-image-reveal {
    animation: hero-image-reveal 3s cubic-bezier(0.22, 1, 0.36, 1) both;
    animation-delay: 200ms;
    opacity: 0;
  }

  .hero-reveal-2 {
    animation-delay: 300ms;
  }

  .hero-reveal-3 {
    animation-delay: 400ms;
  }

  .hero-reveal-4 {
    animation-delay: 500ms;
  }

  .hero-reveal-5 {
    animation-delay: 550ms;
  }

  @keyframes hero-reveal {
    to {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }

  @keyframes hero-image-reveal {
    to {
      opacity: 1;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-reveal,
    .hero-image-reveal {
      animation: none;
      opacity: 1;
      transform: none;
    }
  }
</style>
