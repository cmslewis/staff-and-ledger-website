---
import SectionLabel from "../ui/SectionLabel.astro";

const { block } = Astro.props;
---

<section class="section-y bg-surface">
  <div class="site-shell site-grid">
    <div class="col-span-4 md:col-span-3">
      <SectionLabel label={block.sectionLabel} mark="SL/03" />
    </div>
    <div class="col-span-4 md:col-span-7 lg:col-span-8 lg:col-start-5">
      <p class="font-display text-section-sm leading-tight text-sand-1 md:text-section-md lg:text-section-lg">{block.text}</p>
      <p class="mt-10 max-w-2xl font-serif text-2xl italic leading-10 text-accent">{block.accent}</p>
    </div>
  </div>
</section>
