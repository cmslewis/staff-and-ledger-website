---
const { block } = Astro.props;
const accentParts = String(block.accent ?? "")
  .split(/(_[^_]+_)/g)
  .filter(Boolean);
---

<section class="bg-page">
  <div class="grid border-b border-sand-1/12 lg:grid-cols-[clamp(4rem,5vw,5.75rem)_1fr]">
    <div class="hidden border-r border-sand-1/12 px-6 py-8 lg:block">
      <p class="font-mono text-sm text-sand-1/72">03</p>
    </div>
    <div>
      <div class="border-b border-sand-1/12 px-6 py-5 lg:hidden">
        <p class="font-mono text-sm text-sand-1/72">03</p>
      </div>
      <div class="site-shell grid gap-12 py-16 md:py-20 lg:grid-cols-12 lg:items-center">
        <div class="lg:col-span-6">
          <p class="font-display text-section-sm leading-tight text-sand-1 md:text-section-md">{block.text}</p>
          <p class="mt-3 max-w-4xl font-serif text-3xl italic leading-tight text-accent md:text-5xl">
            {accentParts.map((part) =>
              part.startsWith("_") && part.endsWith("_") ? (
                <em>{part.slice(1, -1)}</em>
              ) : (
                part
              )
            )}
          </p>
        </div>
        <div class="staff-lines min-h-40 text-sand-1/40 lg:col-span-6">
          <a class="group mt-10 flex items-center gap-10 border-y border-sand-1/12 py-6 font-mono text-[0.68rem] uppercase tracking-[0.14em] text-accent transition hover:text-sand-1" href={block.ctaUrl ?? "/about"}>
            <span>{block.ctaLabel ?? "Learn more"}</span>
            <span class="text-xl transition-[translate] duration-300 group-hover:translate-x-2" aria-hidden="true">→</span>
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
