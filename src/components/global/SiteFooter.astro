---
import Logo from "./Logo.astro";
import site from "../../data/site.json";
import navigation from "../../data/navigation.json";
---

<footer class="rule-top bg-page py-12">
  <div class="site-shell site-grid gap-y-10">
    <div class="col-span-4 lg:col-span-5">
      <Logo />
      <p class="mt-8 max-w-md font-serif text-lg leading-8 text-sand-1/72">{site.description}</p>
    </div>
    <nav class="col-span-4 grid gap-3 font-sans text-xs uppercase tracking-[0.16em] text-sand-1/70 lg:col-span-3 lg:col-start-8" aria-label="Footer navigation">
      {navigation.primary.map((item) => <a class="hover:text-accent" href={item.url}>{item.label}</a>)}
    </nav>
    <div class="col-span-4 font-mono text-[0.68rem] uppercase tracking-[0.14em] text-sand-3 lg:col-span-2 lg:col-start-11">
      <p>Contact</p>
      <a class="mt-3 block text-accent" href={`mailto:${site.contactEmail}`}>{site.contactEmail}</a>
    </div>
  </div>
</footer>
